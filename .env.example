# Example environment variables for Vite + Vercel
VITE_GEMINI_API_KEY=your-api-key-here

# =============================================================================
# VVV Digitals Store — Environment Variables
# =============================================================================
# Copy this file to .env (local) and configure the same values in Netlify
# UI under Site settings → Environment variables.
#
# Generate LICENSE_HMAC_SECRET with: openssl rand -hex 32
# =============================================================================

# Stripe (Test mode keys for local dev, Live mode for production)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# SendGrid
SENDGRID_API_KEY=SG....
SENDGRID_FROM_EMAIL=store@vvvdigitals.com

# License signing (HMAC-SHA256). KEEP SECRET. Rotate annually.
# Canonical name. license.js also accepts LICENSE_SIGNING_SECRET as a legacy fallback.
LICENSE_HMAC_SECRET=

# Public site URL (used for redirect URLs and email links).
# Canonical name. The code also accepts VITE_SITE_URL as a fallback.
SITE_URL=https://vvvdigitals.com

# --- Optional (defaults shown) ---
# SENDGRID_FROM_NAME defaults to "VVV Digitals"
# SENDGRID_FROM_NAME=VVV Digitals
# SUPPORT_EMAIL defaults to "support@vvvdigitals.com"
# SUPPORT_EMAIL=support@vvvdigitals.com
